# ═══════════════════════════════════════════════════════════════
#  AFRILEAP BACKEND — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains secrets.
# ═══════════════════════════════════════════════════════════════

# ─── SERVER ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production

# ─── DATABASE (PostgreSQL) ─────────────────────────────────────
# Local dev:  postgresql://postgres:password@localhost:5432/afrileap
# Production: use a managed DB like Supabase, Railway, or Neon
DATABASE_URL=postgresql://postgres:password@localhost:5432/afrileap

# ─── SOLANA ────────────────────────────────────────────────────
# Which cluster to connect to:
#   devnet      → for testing (free SOL from faucet.solana.com)
#   mainnet-beta→ real money, production only
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Your treasury wallet — this receives the $1 USDC verification fees.
# Generate one with: solana-keygen new --outfile treasury-keypair.json
# Then: solana address -k treasury-keypair.json
TREASURY_WALLET_ADDRESS=REPLACE_WITH_YOUR_TREASURY_WALLET_ADDRESS

# USDC mint address (the official USDC contract on each cluster)
# Devnet:   Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
# Mainnet:  EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT_ADDRESS=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# Expected $1 USDC in micro-USDC (USDC has 6 decimal places)
# $1.00 USDC = 1,000,000 micro-USDC
USDC_VERIFICATION_AMOUNT=1000000

# How old (in seconds) a tx can be before we reject it as stale.
# This prevents someone replaying an old valid tx from a different application.
TX_MAX_AGE_SECONDS=300        # 5 minutes

# ─── SECURITY ──────────────────────────────────────────────────
# A strong random string used to sign internal tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Allowed origins for CORS (comma-separated, no trailing slash)
# In dev this is your local HTML file server or localhost:PORT
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Rate limiting: max requests per IP per window
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX_REQUESTS=20    # per IP per window

# ─── LOGGING ───────────────────────────────────────────────────
LOG_LEVEL=debug               # error | warn | info | debug
